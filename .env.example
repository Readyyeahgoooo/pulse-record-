# OPENROUTER_API_KEY: Required on the server for OpenRouter API calls.
# In Vercel, add this in Project Settings -> Environment Variables.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
OPENROUTER_MODEL="openai/gpt-4.1-mini"

# APP_URL: Optional public URL for OpenRouter ranking headers.
APP_URL="https://your-app-domain.vercel.app"

# SCHOOL_NAME: Replace with the real pilot school name before demos or funding exports.
SCHOOL_NAME="MY_SCHOOL_NAME"
